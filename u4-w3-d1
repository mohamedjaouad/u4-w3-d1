-- 1)
SELECT *
FROM clienti
WHERE nome = 'Mario';
-- 2)
SELECT nome, cognome
FROM clienti
WHERE anno_di_nascita = 1982;
-- 3)
SELECT COUNT(*) AS numero_fatture_iva_20
FROM fatture
WHERE iva = 20;
-- 4)
SELECT *
FROM prodotti
WHERE EXTRACT(YEAR FROM data_attivazione) = 2017
  AND (in_produzione = TRUE OR in_commercio = TRUE);
--  5)
SELECT fatture.*, clienti.nome, clienti.cognome, clienti.regione_residenza
FROM fatture
JOIN clienti ON fatture.id_cliente = clienti.numero_cliente
WHERE fatture.importo < 1000;
-- 6)
SELECT fatture.numero_fattura, fatture.importo, fatture.iva, fatture.data_fattura,fornitori.denominazione AS nome_fornitore
FROM fatture 
JOIN fornitori ON fatture.numero_fornitore = fornitori.numero_fornitore;
-- 7)
SELECT EXTRACT(YEAR FROM data_fattura) AS anno,COUNT(*) AS numero_fatture
FROM fatture
WHERE iva = 20
GROUP BY anno
ORDER BY anno;
-- 8)
SELECT EXTRACT(YEAR FROM data_fattura) AS anno,COUNT(*) AS numero_fatture,SUM(importo) AS totale_importi
FROM fatture
GROUP BY anno
ORDER BY anno;
-- 9)
SELECT EXTRACT(YEAR FROM data_fattura) AS anno,COUNT(*) AS numero_fatture
FROM fatture
WHERE tipologia = 'A'
GROUP BY anno;
-- 10)
SELECT clienti.regione_residenza,SUM(fatture.importo) AS totale_importi
FROM fatture
JOIN clienti ON fatture.id_cliente = clienti.numero_cliente
GROUP BY clienti.regione_residenza;
-- 11)
SELECT COUNT(DISTINCT clienti.numero_cliente) AS clienti_con_fatture_over_50
FROM clienti
JOIN fatture ON fatture.id_cliente = clienti.numero_cliente
WHERE clienti.anno_di_nascita = 1980
  AND fatture.importo > 50;


